# ============================================================
# DIU — Variables de entorno
# Copiá este archivo como ".env" y completá los valores reales
# NUNCA subas el archivo .env a git
# ============================================================

# Clave secreta de Flask (generá una larga y aleatoria)
# En Python podés generar una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Credenciales del primer usuario administrador
# (se crean automáticamente la primera vez que corre la app)
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambia-esta-contrasena

# Nombre del administrador
ADMIN_NAME=Administrador

# Entorno: development | production
FLASK_ENV=production

# Puerto (opcional, por defecto 5000)
# PORT=5000
